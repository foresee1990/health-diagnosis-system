server {
    listen 80;

    # 前端页面
    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # 关键：把 /api 请求转发到后端容器
    location /api/ {
        proxy_pass http://backend:8080/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        # SSE 流式响应支持（AI 对话用到）
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300s;
    }
}